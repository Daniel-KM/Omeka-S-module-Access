#: data/scripts/upgrade_vocabulary.php:19
#, php-format
msgid "This module requires module %1$s version %2$s or greater."
msgstr "Ezhomm en deus ar modul-mañ eus ar modul %1$s stumm %2$s pe unan uheloc'h."

#: data/scripts/upgrade.php:42 Module.php:53 Module.php:69
#, php-format
msgid "The module %1$s should be upgraded to version %2$s or later."
msgstr "Ar modul %1$s a zlefe bezañ hizivaet d'ar stumm %2$s pe d'ur stumm nevesoc'h."

#: data/scripts/upgrade.php:46
msgid "Missing requirement. Unable to upgrade."
msgstr "Rekizadenn a vank. N'haller ket hizivaat."

#: Module.php:205
msgid "To be automatically upgraded and replaced by this module, the module \"Access Resource\" should be upgraded first to version 3.4.17.1. Else uninstall it first, but you will lose access statuses and requests."
msgstr "Evit ma vo hizivaet ha kemeret e blas ent emgefreek gant ar modul-mañ, e rank ar modul \"Moned d'ar Mammennoù\" bezañ hizivaet da gentañ d'ar stumm 3.4.17.1. A-hend-all, diinstalit anezhañ da gentañ, met koll a reot ar statudoù moned hag ar goulennoù."

#: Module.php:211
msgid "To be automatically upgraded and replaced by this module, the module \"Access Resource\" should be downgraded first to version 3.4.17.1. Else uninstall it first, but you will lose access statuses and requests."
msgstr "Evit bezañ hizivaet hag erlec'hiet ent emgefre gant ar modul-mañ, e rank ar modul \"Moned d'ar Mammennoù\" bezañ digresket da stumm 3.4.17.1 da gentañ. A-hend-all, diinstalit anezhañ da gentañ, met koll a reot ar statudoù moned hag ar goulennoù."

#: Module.php:726
msgid "Tasks"
msgstr "Kefridioù"

#: Module.php:964
msgid "When properties are used, three properties should be defined for \"level\", \"embargo start\" and \"embargo end\"."
msgstr "Pa vez implijet perzhioù, e tlefe bezañ termenet tri perzh evit \"live\", \"deroù an embargo\" hag \"fin an embargo\"."

