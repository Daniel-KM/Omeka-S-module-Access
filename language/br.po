msgid "An error occurred during migration of module \"{module}\". Check the config and uninstall it manually."
msgstr "Ur fazi zo c'hoarvezet e-pad treuzkas ar modul \"{module}\". Gwiriit ar c'hemenn ha diinstalit anezhañ gant an dorn."

